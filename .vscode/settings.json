{
    // **************************************
    // * VS Code Settings Configuration     *
    // * Project: Armoghan Blogs            *
    // * Description: Configuration for     *
    // * optimizing the development         *
    // * environment for Hugo websites.     *
    // **************************************
    // **************************************
    // * General Editor Settings            *
    // **************************************
    // Auto-save when the window loses focus
    "files.autoSave": "onWindowChange",
    "files.autoSaveDelay": 1000, // Delay before auto-saving files
    // Use Prettier for code formatting
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true, // Automatically format on save
    // Display line numbers and whitespace characters
    "editor.lineNumbers": "on",
    "editor.renderWhitespace": "all",
    "editor.wordWrap": "on", // Wrap lines at viewport width
    // Cursor and tab settings
    "editor.cursorBlinking": "smooth",
    "editor.tabSize": 2,
    "editor.tabCompletion": "on",
    // Suggestion settings
    "editor.suggest.insertMode": "replace",
    "editor.suggest.showSnippets": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestOnTriggerCharacters": true,
    // Code lens and hover settings
    "editor.codeLens": true,
    "editor.hover.enabled": true,
    // **************************************
    // * Appearance Settings               *
    // **************************************
    // Disable minimap and set color theme
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "Shades of Purple",
    // Enable bracket pair colorization
    "editor.bracketPairColorization.enabled": true,
    // **************************************
    // * Terminal Settings                 *
    // **************************************
    // Increase terminal scrollback buffer
    "terminal.integrated.scrollback": 10000,
    "terminal.explorerKind": "both", // Show terminal explorer
    // **************************************
    // * Language Specific Settings         *
    // **************************************
    // JSONC specific settings
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    // Markdown formatting
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "editor.formatOnSave": true
    },
    // XML formatting
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml",
        "editor.formatOnSave": true
    },
    // YAML formatting
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.formatOnSave": true
    },
    "[yml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.formatOnSave": true
    },
    // TOML formatting
    "[toml]": {
        "editor.defaultFormatter": "be5invis.toml",
        "editor.formatOnSave": true
    },
    // Enable validation for specific file types
    "yaml.validate": true,
    "toml.validate": true,
    "xml.format.formatter": "prettier",
    // **************************************
    // * Git Settings                      *
    // **************************************
    // Enable GPG signing and smart commit options
    "git.enableCommitSigning": true,
    "git.enableSmartCommit": true,
    // **************************************
    // * Additional Settings               *
    // **************************************
    // Line endings configuration for WSL
    "files.eol": "\n",
    // File encoding configuration
    "files.encoding": "utf8",
    // Enable bracket auto-closing and quick suggestions
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingTags": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
    },
    // Enable breadcrumbs (file path navigation)
    "breadcrumbs.enabled": true,
    // Enable Markdown linting with default settings
    "markdownlint.config": {
        "default": true
    },
    // **************************************
    // * File Exclusion and Search Settings *
    // **************************************
    // Exclude specific files and folders from the workspace
    "files.exclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/.vscode": true,
        "**/.github": true,
        "**/.devcontainer": true,
        "**/.husky": true,
        "**/package-lock.json": true,
        "**/.hugo_build.lock": true,
        "**/.gitignore": true,
        "**/.prettierrc.js": true,
        "**/commitlint.config.js": true,
        "**/.prettierignore": true,
        "**/eslint.config.mjs": true,
        "**/LICENSE": true,
        "**/SECURITY.md": true,
        "**/CONTRIBUTING.md": true,
        "**/CODE_OF_CONDUCT.md": true
    },
    // Exclude specific files and folders from search results
    "search.exclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/.vscode": true,
        "**/.github": true,
        "**/.devcontainer": true,
        "**/.husky": true
    },
    // Exclude specific files and folders from file watcher
    "files.watcherExclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/.vscode": true,
        "**/.github": true,
        "**/.devcontainer": true,
        "**/.husky": true
    }
}