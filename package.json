{
  "name": "armoghan-blogs",
  "version": "1.0.0",
  "description": "Personal blog built with Hugo and Decap-CMS using the Blowfish theme.",
  "private": "true",
  "scripts": {
    "prettier": "prettier --check --ignore-unknown .",
    "prettier:fix": "prettier --write --ignore-unknown .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "npx lint-staged",
    "prepare": "husky"
  },
  "keywords": [
    "Hugo",
    "Blowfish Theme",
    "Armoghan Blogs",
    "Decap CMS",
    "Personal Blog",
    "Web Development",
    "Static Site Generator",
    "CMS",
    "Tailwind CSS"
  ],
  "browserslist": [
    "last 2 versions",
    "not dead",
    "Chrome >= 80",
    "Firefox >= 80",
    "Safari >= 12"
  ],
  "engines": {
    "node": ">=22.6.0",
    "npm": ">=10.8.2",
    "hugo": ">=0.131.0"
  },
  "author": {
    "name": "Armoghan-ul-Mohmin",
    "email": "armoghanblogs@gmail.com"
  },
  "license": "MIT",
  "licenseFile": "LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armoghan-Blogs/Blogs.git",
    "description": "A personal blog built with Hugo and Decap-CMS, using the Blowfish theme."
  },
  "bugs": {
    "url": "https://github.com/Armoghan-Blogs/Blogs/issues"
  },
  "homepage": "https://github.com/Armoghan-Blogs/Blogs#readme",
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.html": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.css": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.yaml": [
      "prettier --write"
    ],
    "*.toml": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-html": "^8.1.1",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.9.0",
    "husky": "9.1.4",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-toml": "^2.0.1",
    "prettier-plugin-xml": "^0.1.0"
  }
}
